# ============================================================
# BTC Goldbach Day Trader — Configuration
# ============================================================
# cp .env.example .env  →  fill in your values
# ============================================================

# --- Alpaca (REQUIRED) ---
# US-compliant free paper trading for crypto
# Sign up at https://alpaca.markets/signup (free, no KYC for paper)
# Go to Paper Account → API Keys → Generate New Key
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET=your_alpaca_secret
ALPACA_PAPER=true

# Alpaca API endpoint (paper vs live)
# Paper: https://paper-api.alpaca.markets/v2
# Live:  https://api.alpaca.markets/v2
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2

# --- Trading ---
SYMBOL=BTC/USD
TIMEFRAME=15m
RISK_PER_TRADE=0.0025
MAX_DAILY_LOSS=-150
MAX_CONCURRENT_POSITIONS=10
MIN_RISK_REWARD=1.5
INITIAL_EQUITY=10000

# --- Sessions (Eastern Time) ---
AM_SESSION_START=07:00
AM_SESSION_END=12:00
PM_SESSION_START=13:00
PM_SESSION_END=17:00
# Asia session — set both to same value to disable
ASIA_SESSION_START=00:00
ASIA_SESSION_END=00:00

# --- Strategy Parameters ---
GOLDBACH_LOOKBACK=30
GOLDBACH_TOLERANCE=0.012
PO3_BREAKOUT_SL_MULT=0.04
BREAK_EVEN_TRIGGER=0.5

# --- TradingView MCP (Optional) ---
# Launch TradingView Desktop with: --remote-debugging-port=9222
TV_ENABLED=false
TV_CDP_PORT=9222

# --- Telegram Alerts (Optional) ---
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Optimizer ---
OPTIMIZER_RUN_HOUR=0
OPTIMIZER_LOOKBACK_DAYS=14

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=./logs

# --- OANDA (Forex) ---
# Sign up at https://www.oanda.com (free practice account)
# Manage API Access → Generate token
OANDA_TOKEN=your_oanda_token
OANDA_ACCOUNT_ID=your_account_id
OANDA_ENVIRONMENT=practice
FOREX_PAIRS=EUR/USD,GBP/USD,USD/JPY
